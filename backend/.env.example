# PostgreSQL Database Connection
# Use the Supavisor Pooler (Port 6543) for IPv4 compatibility and serverless handling
# Mode: Transaction
# Format: postgresql://postgres.<PROJECT-REF>:[PASSWORD]@[POOLER-HOSTNAME]:6543/postgres
DATABASE_URL=postgresql://postgres.yourprojectref:yourpassword@aws-1-your-region.pooler.supabase.com:6543/postgres

# Project Settings
PROJECT_NAME="AI Job Matching API"
VERSION="1.0.0"
ENVIRONMENT="development"
HUGGING_FACE_API_TOKEN="your_hf_token_here"

# CORS
ALLOWED_ORIGINS="https://your-frontend.vercel.app,http://localhost:3000"
